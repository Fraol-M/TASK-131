{
  "name": "@nexusorder/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "NexusOrder Desk — Electron desktop shell",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "package": "npm run build && electron-builder --win --config electron-builder.yml",
    "test": "vitest run"
  },
  "dependencies": {
    "@nexusorder/service": "workspace:*",
    "@nexusorder/shared-logging": "workspace:*",
    "@nexusorder/shared-rbac": "workspace:*",
    "@nexusorder/shared-types": "workspace:*",
    "@nexusorder/shared-validation": "workspace:*",
    "@tanstack/react-query": "^5.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.4",
    "react-router-dom": "^6.23.1",
    "zustand": "^4.5.2",
    "zod": "^3.23.0",
    "electron-updater": "^6.1.8",
    "undici": "^6.18.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.6",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.5.0"
  }
}
