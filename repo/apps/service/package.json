{
  "name": "@nexusorder/service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "nodemon --exec \"node --loader ts-node/esm\" src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose tests/unit",
    "test:integration": "vitest run --reporter=verbose tests/integration",
    "db:indexes": "node --loader ts-node/esm src/persistence/runIndexes.ts",
    "db:seed": "node --loader ts-node/esm ../../database/seed/seed.ts"
  },
  "dependencies": {
    "@nexusorder/shared-logging": "workspace:*",
    "@nexusorder/shared-rbac": "workspace:*",
    "@nexusorder/shared-types": "workspace:*",
    "@nexusorder/shared-validation": "workspace:*",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "argon2": "^0.31.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jose": "^5.4.0",
    "mongodb": "^6.6.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-forge": "^1.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/archiver": "^6.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-forge": "^1.3.11",
    "@types/supertest": "^6.0.2",
    "nodemon": "^3.1.3",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
