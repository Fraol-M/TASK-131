# NexusOrder Desk — Environment Configuration
# Copy this file to .env and fill in values before running.

# ─── Service Layer ────────────────────────────────────────────────────────────
SERVICE_PORT=4433
SERVICE_HOST=127.0.0.1
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/nexusorder
MONGODB_DB_NAME=nexusorder

# ─── TLS (localhost IPC) ──────────────────────────────────────────────────────
# Paths to locally-generated TLS cert/key for localhost HTTPS
TLS_CERT_PATH=./certs/localhost.crt
TLS_KEY_PATH=./certs/localhost.key

# ─── Session ──────────────────────────────────────────────────────────────────
# 256-bit hex secret for signing session tokens
SESSION_SECRET=REPLACE_WITH_64_HEX_CHARS_SECRET_HERE
SESSION_TTL_SECONDS=28800

# ─── Encryption ───────────────────────────────────────────────────────────────
# 256-bit hex key for AES-256 at-rest field encryption
FIELD_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS_KEY_HERE

# ─── Reconciliation ───────────────────────────────────────────────────────────
# Path to the pre-provisioned merchant RSA public key PEM file
WECHAT_MERCHANT_PUBLIC_KEY_PATH=./keys/wechat_merchant_public.pem

# ─── Backup ───────────────────────────────────────────────────────────────────
BACKUP_DESTINATION_PATH=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_CRON=0 2 * * *

# ─── Checkout Throttle ────────────────────────────────────────────────────────
CHECKOUT_MAX_ATTEMPTS=10
CHECKOUT_WINDOW_MINUTES=10

# ─── Order Lifecycle ──────────────────────────────────────────────────────────
ORDER_AUTO_CANCEL_MINUTES=30
ORDER_AUTO_CLOSE_DAYS=14

# ─── Auth Lockout ─────────────────────────────────────────────────────────────
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# ─── Internal IPC ─────────────────────────────────────────────────────────────
# Pre-shared key used by Electron main process → service for update routes.
# Must be at least 32 chars. Keep this secret — never expose to the renderer.
INTERNAL_API_KEY=REPLACE_WITH_MIN_32_CHAR_RANDOM_STRING_HERE

# ─── Backup Encryption ────────────────────────────────────────────────────────
# 256-bit hex key for AES-256-GCM encryption of backup archive files.
BACKUP_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS_KEY_HERE
